<% title = @secret.try(:name).presence || @secret.foreign_id.presence || @secret.oid %>
<% content_for :title, "Edit #{title} · Centaur Console" %>

<div class="mb-8">
  <a href="<%= console_secret_path(@kind, @secret.oid) %>" class="back-link">← back to secret</a>
  <div class="mt-2 flex flex-wrap items-center gap-3">
    <h1 class="page-title">Edit <%= title %></h1>
    <span class="resource-badge"><%= secret_kind_label(@kind) %></span>
  </div>
</div>

<%= render "errors", secret: @secret %>
<%= render "form_#{@kind}", secret: @secret %>
