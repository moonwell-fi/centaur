#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"
NAMESPACE="${CENTAUR_NAMESPACE:-centaur}"
DEPLOYMENT="${CENTAUR_MIGRATIONS_DEPLOYMENT:-centaur-centaur-api}"
CORE_MIGRATIONS_HOST_DIR="${CENTAUR_MIGRATIONS_HOST_DIR:-$REPO_ROOT/services/api/db/migrations}"
CORE_MIGRATIONS_CONTAINER_DIR="${CENTAUR_MIGRATIONS_CONTAINER_DIR:-/app/db/migrations}"
OVERLAY_HOST_ROOT="${CENTAUR_OVERLAY_HOST_DIR:-${REPO_ROOT}/../centaur-paradigm}"
OVERLAY_CONTAINER_ROOT="${CENTAUR_OVERLAY_DIR:-/app/overlay/org}"
OVERLAY_MIGRATIONS_HOST_DIR="${OVERLAY_HOST_ROOT}/services/api/db/migrations"
OVERLAY_MIGRATIONS_CONTAINER_DIR="${OVERLAY_CONTAINER_ROOT}/services/api/db/migrations"
CORE_MIGRATIONS_TABLE="schema_migrations"
OVERLAY_MIGRATIONS_TABLE="schema_migrations_overlay"
SELECTED_SET=""

usage() {
  cat <<'EOF'
Usage:
  ./scripts/dbmate [--set core|overlay] new <name>
  ./scripts/dbmate [--set core|overlay] <dbmate args>

Examples:
  ./scripts/dbmate new add_usage_rollups
  ./scripts/dbmate --set overlay new create_policy_tables
  ./scripts/dbmate status
  ./scripts/dbmate up
  ./scripts/dbmate rollback

When DATABASE_URL is not set in the host shell, the wrapper reuses the value
from the running API pod.
EOF
}

die() {
  printf 'error: %s\n' "$1" >&2
  exit 1
}

normalize_name() {
  printf '%s' "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9]+/_/g; s/^_+//; s/_+$//; s/_+/_/g'
}

list_sets() {
  printf 'core\n'
  if [[ -d "$OVERLAY_MIGRATIONS_HOST_DIR" ]]; then
    printf 'overlay\n'
  fi
}

resolve_set_dir() {
  case "$1" in
    core)
      printf '%s\n%s\n%s\n' \
        "$CORE_MIGRATIONS_HOST_DIR" \
        "$CORE_MIGRATIONS_CONTAINER_DIR" \
        "$CORE_MIGRATIONS_TABLE"
      ;;
    overlay)
      [[ -d "$OVERLAY_MIGRATIONS_HOST_DIR" ]] || die "overlay migrations dir not found: $OVERLAY_MIGRATIONS_HOST_DIR"
      printf '%s\n%s\n%s\n' \
        "$OVERLAY_MIGRATIONS_HOST_DIR" \
        "$OVERLAY_MIGRATIONS_CONTAINER_DIR" \
        "$OVERLAY_MIGRATIONS_TABLE"
      ;;
    *)
      die "unknown migration set: $1"
      ;;
  esac
}

target_sets_for_command() {
  if [[ -n "$SELECTED_SET" ]]; then
    printf '%s\n' "$SELECTED_SET"
    return
  fi

  case "$1" in
    up|migrate|status|create|wait|dump|load)
      list_sets
      ;;
    *)
      printf 'core\n'
      ;;
  esac
}

next_migration_number() {
  local migrations_host_dir="$1"
  mkdir -p "$migrations_host_dir"

  local latest
  latest="$({
    find "$migrations_host_dir" -maxdepth 1 -type f -name '*.sql' -printf '%f\n' 2>/dev/null \
      | sed -nE 's/^([0-9]+)_.+\.sql$/\1/p' \
      | sort -n
  } | tail -n 1)"

  if [[ -z "$latest" ]]; then
    printf '001'
    return
  fi

  local width next
  width=${#latest}
  next=$((10#$latest + 1))
  printf "%0${width}d" "$next"
}

create_migration() {
  local migration_set="$1"
  local raw_name="$2"
  local -a _set_config
  local migrations_host_dir slug path number

  mapfile -t _set_config < <(resolve_set_dir "$migration_set")
  migrations_host_dir="${_set_config[0]}"

  slug="$(normalize_name "$raw_name")"
  [[ -n "$slug" ]] || die "migration name must contain letters or numbers"

  number="$(next_migration_number "$migrations_host_dir")"
  path="$migrations_host_dir/${number}_${slug}.sql"
  [[ ! -e "$path" ]] || die "migration already exists: $path"

  cat > "$path" <<'EOF'
-- migrate:up

-- migrate:down
EOF

  printf 'created [%s] %s\n' "$migration_set" "$path"
}

resolve_database_url() {
  if [[ -n "${DATABASE_URL:-}" ]]; then
    printf '%s' "$DATABASE_URL"
    return
  fi

  if ! command -v kubectl >/dev/null 2>&1; then
    die "kubectl is required unless DATABASE_URL is already set"
  fi

  local database_url
  if ! database_url="$(kubectl -n "$NAMESPACE" exec "deploy/$DEPLOYMENT" -- printenv DATABASE_URL 2>/dev/null | tr -d '\r')"; then
    die "could not read DATABASE_URL from deploy/$DEPLOYMENT in namespace $NAMESPACE; start it with 'just up' or set DATABASE_URL"
  fi
  [[ -n "$database_url" ]] || die "DATABASE_URL is empty in deploy/$DEPLOYMENT"
  printf '%s' "$database_url"
}

run_dbmate_for_set() {
  local migration_set="$1"
  shift
  command -v kubectl >/dev/null 2>&1 || die "kubectl is required to run dbmate commands"

  local -a _set_config
  local database_url dbmate_url sep migrations_container_dir migrations_table
  mapfile -t _set_config < <(resolve_set_dir "$migration_set")
  migrations_container_dir="${_set_config[1]}"
  migrations_table="${_set_config[2]}"

  database_url="$(resolve_database_url)"
  dbmate_url="$database_url"
  if [[ "$dbmate_url" != *sslmode=* ]]; then
    sep='?'
    [[ "$dbmate_url" == *\?* ]] && sep='&'
    dbmate_url+="${sep}sslmode=disable"
  fi

  kubectl -n "$NAMESPACE" exec "deploy/$DEPLOYMENT" -- \
    env DATABASE_URL="$dbmate_url" \
    dbmate \
    --url "$dbmate_url" \
    --migrations-dir "$migrations_container_dir" \
    --migrations-table "$migrations_table" \
    --no-dump-schema \
    "$@"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --set)
      shift
      [[ $# -gt 0 ]] || die "usage: ./scripts/dbmate --set <core|overlay> ..."
      SELECTED_SET="$1"
      ;;
    *)
      break
      ;;
  esac
  shift
done

case "${1:-}" in
  ""|help|-h|--help)
    usage
    ;;
  new)
    shift
    [[ $# -gt 0 ]] || die "usage: ./scripts/dbmate new <name>"
    create_migration "${SELECTED_SET:-core}" "$*"
    ;;
  *)
    mapfile -t _target_sets < <(target_sets_for_command "$1")
    for _set in "${_target_sets[@]}"; do
      printf '==> [%s] dbmate %s\n' "$_set" "$*" >&2
      run_dbmate_for_set "$_set" "$@"
    done
    ;;
esac
