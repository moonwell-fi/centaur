{
  "schema": "centaur.slackbot_synthetic_rendering_cases.v1",
  "description": "Synthetic SSE/session event sequences for Slackbot v2 renderer regression tests.",
  "cases": [
    {
      "case_id": "nested_terminal_result_loses_final_text",
      "issue": "Terminal result text nested under result.text is not rendered as markdown_text.",
      "events": [
        {
          "id": 1,
          "event": "session.output.line",
          "data": "{\"type\":\"turn.done\",\"result\":{\"text\":\"Final answer\"}}"
        }
      ],
      "expected_regression_assertion": "Slack stream should contain visible final text or renderer should normalize nested terminal result text."
    },
    {
      "case_id": "plain_output_line_stops_before_answer",
      "issue": "Slackbot session parser treats malformed/plain session.output.line as terminal and stops before later final answer.",
      "events": [
        {
          "id": 1,
          "event": "session.output.line",
          "data": "warning: reconnecting"
        },
        {
          "id": 2,
          "event": "session.output.line",
          "data": "{\"type\":\"turn.done\",\"result\":\"Final answer\"}"
        }
      ],
      "expected_regression_assertion": "Plain output should not stop stream consumption before a later terminal answer."
    },
    {
      "case_id": "terminal_before_final_delta",
      "issue": "Parser returns on turn.completed, so later final_answer deltas are ignored.",
      "events": [
        {
          "id": 1,
          "event": "session.output.line",
          "data": "{\"method\":\"turn/plan/updated\",\"params\":{\"explanation\":\"Plan\",\"plan\":[{\"step\":\"Check logs\",\"status\":\"completed\"}]}}"
        },
        {
          "id": 2,
          "event": "session.output.line",
          "data": "{\"method\":\"turn/completed\",\"params\":{\"turn\":{\"id\":\"t1\",\"status\":\"completed\"}}}"
        },
        {
          "id": 3,
          "event": "session.output.line",
          "data": "{\"method\":\"item/agentMessage/delta\",\"params\":{\"turnId\":\"t1\",\"itemId\":\"answer-1\",\"delta\":\"Final answer\"}}"
        }
      ],
      "expected_regression_assertion": "Renderer should not report final completion before final-answer deltas are consumed."
    },
    {
      "case_id": "final_text_classified_as_commentary",
      "issue": "Final-looking text with phase=commentary renders inside Thinking task and not final markdown.",
      "events": [
        {
          "id": 1,
          "event": "session.output.line",
          "data": "{\"method\":\"item/started\",\"params\":{\"turnId\":\"t1\",\"item\":{\"id\":\"m1\",\"type\":\"agentMessage\",\"phase\":\"commentary\",\"text\":\"\"}}}"
        },
        {
          "id": 2,
          "event": "session.output.line",
          "data": "{\"method\":\"item/agentMessage/delta\",\"params\":{\"turnId\":\"t1\",\"itemId\":\"m1\",\"delta\":\"Final answer\"}}"
        },
        {
          "id": 3,
          "event": "session.output.line",
          "data": "{\"method\":\"item/completed\",\"params\":{\"turnId\":\"t1\",\"item\":{\"id\":\"m1\",\"type\":\"agentMessage\",\"phase\":\"commentary\",\"text\":\"Final answer\"}}}"
        },
        {
          "id": 4,
          "event": "session.output.line",
          "data": "{\"method\":\"turn/completed\",\"params\":{\"turn\":{\"id\":\"t1\"}}}"
        }
      ],
      "expected_regression_assertion": "Thinking task must not be the only visible location for final-answer content."
    },
    {
      "case_id": "execution_failed_error_not_markdown",
      "issue": "Failure event marks tasks as error, but renderer.done.error is filtered before Slack markdown.",
      "events": [
        {
          "id": 1,
          "event": "session.output.line",
          "data": "{\"method\":\"turn/plan/updated\",\"params\":{\"explanation\":\"Plan\",\"plan\":[{\"step\":\"Run command\",\"status\":\"inProgress\"}]}}"
        },
        {
          "id": 2,
          "event": "session.execution_failed",
          "data": "{\"error\":\"sandbox exited\"}"
        }
      ],
      "expected_regression_assertion": "Slack should include visible error text, not only an error-state plan task."
    }
  ]
}
